# ============================================
# Judi-Expert — Configuration par défaut
# ============================================
# Ce fichier est embarqué dans l'installateur et copié
# comme .env lors de l'installation.
# L'expert peut le modifier après installation si nécessaire.

# --- Base de données locale (SQLite) ---
DATABASE_URL=sqlite:///./data/judi-expert.db

# --- Service LLM (Ollama) ---
LLM_HOST=http://judi-llm:11434
LLM_MODEL=mistral:7b-instruct-v0.3

# --- Service RAG (Qdrant) ---
QDRANT_HOST=http://judi-rag:6333

# --- Service OCR ---
OCR_HOST=http://judi-ocr:8001

# --- Authentification locale (JWT) ---
JWT_SECRET=CHANGEZ_MOI_secret_jwt_local
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- Site Central (vérification de tickets) ---
SITE_CENTRAL_URL=https://www.judi-expert.fr

# --- Domaine d'expertise actif ---
DOMAINE=psychologie
