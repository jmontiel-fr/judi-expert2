# ============================================
# Judi-Expert — Site Central Production (.env.prod)
# ============================================
# Copier en .env.prod et renseigner les valeurs.
# Ce fichier NE DOIT PAS être commité dans Git.

# --- Base de données (RDS PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://judi:MOT_DE_PASSE@ENDPOINT_RDS:5432/judi_expert

# --- Application ---
APP_ENV=production
APP_URL=https://judi-expert.fr

# --- AWS ---
AWS_REGION=eu-west-3

# --- Cognito ---
COGNITO_USER_POOL_ID=eu-west-3_XXXXXXX
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXX

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE
STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET

# --- Ticket Token ---
TICKET_SECRET=GENEREZ_UN_SECRET_ALEATOIRE_64_CHARS
TICKET_VALIDITY_HOURS=48

# --- Email (SMTP Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
SMTP_FROM_NAME=Judi-Expert

# --- reCAPTCHA V2 ---
RECAPTCHA_SITE_KEY=VOTRE_CLE_SITE
RECAPTCHA_SECRET_KEY=VOTRE_CLE_SECRETE

# --- Administration ---
ADMIN_EMAIL=admin@judi-expert.fr
ADMIN_DEFAULT_PASSWORD=CHANGEZ_MOI

# --- Domaines ---
DOMAINES_YAML_PATH=/data/domaines/domaines.yaml
